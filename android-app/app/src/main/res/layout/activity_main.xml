<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price Finder"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="검색어를 한 번 입력하고 쇼핑몰별로 검색하세요."
            android:textSize="16sp" />

        <EditText
            android:id="@+id/queryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:hint="예: RTX 4060"
            android:inputType="text"
            android:minHeight="56dp"
            android:padding="14dp" />

        <Button
            android:id="@+id/naverButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="네이버 쇼핑 검색" />

        <Button
            android:id="@+id/daangnButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="당근 검색" />

        <Button
            android:id="@+id/joonggonaraButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="중고나라 검색" />

        <Button
            android:id="@+id/bunjangButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="번개장터 검색" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="상품 검색에는 인터넷 연결이 필요합니다. 별도 PC 서버는 필요하지 않습니다."
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
